# Скопируйте в frontend/.env.

# Базовый URL Envoy gRPC-Web прокси.
# Необязательная переменная — при отсутствии используется значение по умолчанию http://localhost:8080.
# Docker-сборка: значение задаётся через build arg из корневого .env (VITE_APP_GRPC_BASE_URL).
VITE_APP_GRPC_BASE_URL=http://localhost:8080

# Публичный базовый URL MinIO/S3 для отображения превью скриншотов в браузере.
# Необязательная переменная — при отсутствии используется http://localhost:9000.
VITE_APP_S3_PUBLIC_URL=http://localhost:9000
