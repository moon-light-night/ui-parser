# Скопируйте этот файл в .env и укажите свои значения.
# Используется при запуске backend вне Docker (локально).

# База данных
DATABASE_URL=postgresql+psycopg://ui_parser:change_me@localhost:5432/ui_parser

# Redis
REDIS_URL=redis://localhost:6379/0

# gRPC-сервер
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_REGION=us-east-1
S3_BUCKET=screenshots

# Analyzer gRPC
ANALYZER_GRPC_HOST_ADDR=localhost
ANALYZER_GRPC_PORT=50061
ANALYZE_TIMEOUT_SECONDS=600

# Окружение
ENVIRONMENT=development
