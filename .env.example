# Скопируйте этот файл в .env и укажите свои значения.

# PostgreSQL
POSTGRES_DB=ui_parser
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me

# MinIO / S3-совместимое объектное хранилище
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me

# Учётные данные S3, передаваемые бэкенду и анализатору (должны совпадать с учётными данными MinIO выше)
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_REGION=us-east-1
S3_BUCKET=screenshots

# Фронтенд — базовый URL Envoy gRPC-Web прокси (вшивается в статику при сборке)
# Для локальной разработки с `npm run dev` оставьте пустым — Vite dev proxy подхватит сам
VITE_APP_GRPC_BASE_URL=http://localhost:8080

# Фронтенд — публичный базовый URL MinIO/S3 для отображения превью скриншотов
VITE_APP_S3_PUBLIC_URL=http://localhost:9000